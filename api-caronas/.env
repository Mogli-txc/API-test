# =============================================
# VARIÁVEIS DE AMBIENTE - API de Caronas
# =============================================
# O que mudou:
# - DB_DATABASE renomeado para DB_NAME (para bater com database.js)
# - DB_SERVER renomeado para DB_HOST (nome padrão do mysql2)
# - Adicionado DB_NAME com o nome real do banco de dados
# =============================================

# Porta em que a API vai rodar
PORT=3000

# Ambiente (development ou production)
NODE_ENV=development

# Exibe log de cada requisição recebida (true ou false)
LOG_REQUESTS=true

# --- Configurações do Banco de Dados MySQL ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=teste
DB_NAME=bd_tcc_des_125_carona

# --- Segredo para gerar tokens JWT ---
JWT_SECRET=CHAVE_SUPER_SECRETA_API_CARONAS

# --- URL base da API (usada para montar URLs públicas de imagens) ---
API_BASE_URL=http://localhost:3000
