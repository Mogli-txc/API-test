# ==========================================
# SERVIDOR
# ==========================================
PORT=3000
NODE_ENV=development
LOG_REQUESTS=true

# ==========================================
# BANCO DE DADOS
# ==========================================
DB_HOST=your_host_here
DB_PORT=3306
DB_USER=your_user_here
DB_PASSWORD=your_password_here
DB_NAME=your_database_here

# ==========================================
# AUTENTICAÇÃO JWT
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==========================================
JWT_SECRET=your_random_64_byte_hex_here
JWT_EXPIRES_IN=24h

# ==========================================
# SEGREDO OTP (separado do JWT_SECRET por segurança)
# Se JWT_SECRET vazar, OTP_SECRET permanece íntegro e vice-versa.
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==========================================
OTP_SECRET=your_other_random_64_byte_hex_here

# ==========================================
# URL BASE DA APLICAÇÃO — OBRIGATÓRIA
# Usada no link de redefinição de senha enviado por e-mail.
# Dev: http://localhost:3000  |  Prod: https://seudominio.com
# ==========================================
APP_URL=http://localhost:3000

# ==========================================
# CORS — origens permitidas (separadas por vírgula)
# Inclua a URL do seu front-end. Ex: http://localhost:5173 para Vite.
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================================
# EMAIL (SMTP) — para envio de OTP
# Gmail: SMTP_HOST=smtp.gmail.com | SMTP_PORT=587 | SMTP_SECURE=false
# Use uma App Password do Google, não a senha da conta.
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_app_password_aqui
SMTP_FROM="Sistema de Caronas <seu_email@gmail.com>"
